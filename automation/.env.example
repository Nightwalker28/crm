# Copy this file to automation/.env and fill in the real values.

GITHUB_REPO=Nightwalker28/crm
BASE_BRANCH=main
REPO_DIR=/home/nightwalker28/Projects/crm

# Paste your private Discord webhook URL here in automation/.env only.
DISCORD_WEBHOOK_URL=

# Runner behavior
CODEX_TIMEOUT_SECONDS=7200
CREATE_DRAFT_PR=true
CODEX_MAX_REPAIR_ATTEMPTS=2

# Codex execution behavior. Keep this at workspace-write for normal autonomous runs.
CODEX_SANDBOX=workspace-write

# Extra Codex CLI args, for example:
# CODEX_EXTRA_ARGS=--profile my-runner-profile
CODEX_EXTRA_ARGS=

# Dangerous: only enable in an externally sandboxed environment you fully trust.
# This bypasses Codex approvals and sandboxing.
CODEX_BYPASS_APPROVALS_AND_SANDBOX=false
