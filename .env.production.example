# Copy to .env.production and set real secrets/hosts before deployment.

# Public URLs
FRONTEND_ORIGIN=https://crm.example.com
NEXT_PUBLIC_API_BASE_URL=https://api.crm.example.com

# If Postgres/Redis run on the Docker host, use host.docker.internal with the
# host-gateway mapping in docker-compose.prod.yml.
DATABASE_URL=postgresql://lynk:change-me@host.docker.internal:5432/lynk_crm

# Use Redis databases that are not shared with other applications.
# REDIS_URL is app cache/rate-limit storage; CELERY_BROKER_URL is the queue broker.
REDIS_URL=redis://host.docker.internal:6379/2
CELERY_BROKER_URL=redis://host.docker.internal:6379/3

# Bind to localhost when a reverse proxy terminates TLS on the host.
FRONTEND_BIND=127.0.0.1:3000
BACKEND_BIND=127.0.0.1:8000

# Security
DEBUG=false
JWT_SECRET=replace-with-a-long-random-secret
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
ALLOWED_DOMAINS=example.com

# First-run bootstrap admin. Remove or leave unchanged after the first boot.
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=replace-with-a-strong-initial-password
INITIAL_ADMIN_FIRST_NAME=System
INITIAL_ADMIN_LAST_NAME=Admin

# Optional OAuth/provider settings
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=
MAIL_CREDENTIAL_SECRET=

# Runtime sizing
WEB_CONCURRENCY=2
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
